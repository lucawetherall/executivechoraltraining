---
import BaseLayout from '../layouts/BaseLayout.astro';
import OutcomeTile from '../components/OutcomeTile.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import CtaBand from '../components/CtaBand.astro';

const leadershipIcon = `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><path d="M24 4v20M14 14l10 10 10-10M8 34h32M12 40h24"/></svg>`;
const teamIcon = `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><circle cx="16" cy="16" r="6"/><circle cx="32" cy="16" r="6"/><circle cx="24" cy="32" r="6"/><path d="M10 28a12 12 0 0 1 28 0"/></svg>`;
const presenceIcon = `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><circle cx="24" cy="20" r="8"/><path d="M8 44c0-8.837 7.163-16 16-16s16 7.163 16 16"/><path d="M24 4v4M36 8l-3 3M40 20h-4"/></svg>`;
const wellbeingIcon = `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><path d="M24 42s-16-10-16-22a10 10 0 0 1 16-8 10 10 0 0 1 16 8c0 12-16 22-16 22z"/></svg>`;
---

<BaseLayout
  title="Executive Choral Conducting Training — Feel What Leadership Sounds Like"
  description="Choral conducting training that builds presence, communication, and trust — delivered by a professional choir. Corporate leadership development by ECCT."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__overlay"></div>
    <div class="hero__content container">
      <h1>Teach your leaders to conduct.</h1>
      <p class="hero__sub">Choral conducting training that builds presence, communication, and trust — delivered by a professional choir.</p>
      <div class="hero__ctas">
        <a href="/contact/#booking" class="btn btn--primary">Book a Free Consultation</a>
        <a href="/packages/" class="btn btn--secondary">See Our Packages</a>
      </div>
    </div>
  </section>

  <!-- Problem / Opportunity -->
  <section class="section">
    <div class="container">
      <div class="prose text-center">
        <p class="lead"><strong>Most leadership training talks about communication. Ours makes you do it.</strong></p>
        <p>You stand in front of a professional choir. No slides, no scripts, no jargon. Just your hands, your breath, and your intent. The music responds to your leadership in real time — honestly, immediately, and without compromise. Get the gesture right and thirty voices lock together. Hesitate, and you hear it.</p>
        <p>This is not a metaphor for leadership. It is leadership, stripped to its essentials: clarity of instruction, quality of listening, and the courage to commit.</p>
      </div>
    </div>
  </section>

  <!-- Four Outcomes -->
  <section class="section section--light">
    <div class="container">
      <div class="grid-2">
        <OutcomeTile
          heading="Leadership & Communication"
          description="Learn to lead without speaking. Conducting demands that every instruction is clear, intentional, and legible to an ensemble watching your every move."
          icon={leadershipIcon}
        />
        <OutcomeTile
          heading="Team Cohesion & Trust"
          description="A choir only works when everyone listens. Your team will experience collective attention, mutual dependence, and shared achievement in a way no breakout room can replicate."
          icon={teamIcon}
        />
        <OutcomeTile
          heading="Presence & Confidence"
          description="There is nowhere to hide on the podium. Conducting a professional choir requires total physical and psychological commitment — and rewards it with immediate, audible results."
          icon={presenceIcon}
        />
        <OutcomeTile
          heading="Wellbeing & Stress Relief"
          description="Choral singing is clinically evidenced to reduce cortisol and improve mood. Your team won't just learn together — they'll feel better for it."
          icon={wellbeingIcon}
        />
      </div>
    </div>
  </section>

  <!-- Video Feature -->
  <section class="section">
    <div class="container">
      <VideoEmbed caption="Our professional choir, the Alma Consort, in performance." />
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section section--light">
    <div class="container">
      <div class="logos-bar">
        <div class="logos-bar__placeholder">Client logos</div>
      </div>
      <TestimonialCarousel />
    </div>
  </section>

  <!-- Final CTA -->
  <CtaBand
    headline="Your first session is free."
    body="We offer a complimentary conducting consultation with an Oxford University music tutor. No commitment, no cost — just a conversation about what this could do for your team."
    buttonText="Book Now"
    buttonLink="/contact/#booking"
  />
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f1a2e 0%, #1B2A4A 50%, #2a3d6b 100%);
    overflow: hidden;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: var(--white);
    padding: 2rem 1.5rem;
  }

  .hero__content h1 {
    color: var(--white);
    margin-bottom: 1.25rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__sub {
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto 2.5rem;
    opacity: 0.9;
    line-height: 1.7;
  }

  .hero__ctas {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .lead {
    font-size: 1.35rem;
    line-height: 1.6;
  }

  .logos-bar {
    margin-bottom: 3rem;
  }

  .logos-bar__placeholder {
    text-align: center;
    padding: 2rem;
    border: 2px dashed #ccc;
    border-radius: 8px;
    color: var(--mid-grey);
    font-size: 0.9rem;
  }

  @media (min-width: 640px) {
    .hero__ctas {
      flex-direction: row;
      justify-content: center;
    }
  }
</style>
