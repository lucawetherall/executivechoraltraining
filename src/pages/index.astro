---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
---

<BaseLayout
  title="Executive Choral Conducting Training — Feel What Leadership Sounds Like"
  description="Choral conducting training that builds presence, communication, and trust — delivered by a professional choir. Corporate leadership development by ECCT."
>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="hero" aria-label="Hero">
    <!-- Ambient orbs — depth layer only -->
    <div class="hero__orb hero__orb--sage" aria-hidden="true"></div>
    <div class="hero__orb hero__orb--blue" aria-hidden="true"></div>

    <!-- Conducting arc SVG -->
    <svg class="hero__arc" viewBox="0 0 1000 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
      <path d="M 0 220 Q 500 20 1000 220" stroke="#b7c6c2" stroke-width="1" fill="none"/>
    </svg>

    <!-- Text block -->
    <div class="hero__text" aria-label="Site headline">
      <p class="hero__line hero__line--solid">TEACH YOUR</p>
      <p class="hero__line hero__line--outline">LEADERS.</p>
    </div>

    <!-- Bottom row -->
    <div class="hero__bottom">
      <p class="hero__tagline">Choral conducting training that builds presence, communication, and trust — delivered by the Alma Consort, a professional London choir.</p>
      <a href="/packages/" class="hero__arrow" aria-label="See our packages">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="20" height="20">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Stave divider -->
  <svg class="stave-divider" viewBox="0 0 1440 64" preserveAspectRatio="none" aria-hidden="true">
    <line x1="0" y1="20" x2="1440" y2="20" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="28" x2="1440" y2="28" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="36" x2="1440" y2="36" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="44" x2="1440" y2="44" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="52" x2="1440" y2="52" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
  </svg>

  <!-- ============================================================
       PROBLEM / PREMISE  —  pp (pianissimo: very quiet)
  ============================================================ -->
  <section class="section premise-section">
    <div class="premise-grid container">
      <div class="premise__left">
        <span class="dynamic-mark" style="color: var(--navy);">pp</span>
        <p class="premise__body">Most leadership training talks about communication. Ours makes you do it.</p>
        <p class="premise__body premise__body--secondary">You stand in front of a professional choir. No slides, no scripts, no jargon. Just your hands, your breath, and your intent. The music responds to your leadership in real time — honestly, immediately, and without compromise.</p>
      </div>
      <div class="premise__right reveal">
        <p class="premise__stat">30</p>
        <p class="premise__stat-caption">professional voices respond to your leadership in real time. Get the gesture right and they lock together. Hesitate, and you hear it.</p>
      </div>
    </div>
  </section>

  <!-- Stave divider -->
  <svg class="stave-divider" viewBox="0 0 1440 64" preserveAspectRatio="none" aria-hidden="true">
    <line x1="0" y1="20" x2="1440" y2="20" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="28" x2="1440" y2="28" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="36" x2="1440" y2="36" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="44" x2="1440" y2="44" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="52" x2="1440" y2="52" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
  </svg>

  <!-- ============================================================
       OUTCOMES  —  mp (mezzo-piano: medium quiet)
  ============================================================ -->
  <section class="section outcomes-section">
    <div class="outcomes-heading-wrap">
      <span class="dynamic-mark outcomes-mark" style="color: var(--navy);">mp</span>
      <h2 class="outcomes-heading">What<br/>Changes</h2>
    </div>

    <hr class="outcomes-rule" aria-hidden="true"/>

    <ul class="outcomes-list" role="list">
      <li class="outcome-item reveal">
        <span class="outcome-item__line" aria-hidden="true"></span>
        <span class="outcome-item__num">01</span>
        <div class="outcome-item__content">
          <strong class="outcome-item__title">Leadership &amp; Communication</strong>
          <p class="outcome-item__body">Learn to lead without speaking. Conducting demands that every instruction is clear, intentional, and legible to an ensemble watching your every move.</p>
        </div>
      </li>
      <li class="outcome-item reveal">
        <span class="outcome-item__line" aria-hidden="true"></span>
        <span class="outcome-item__num">02</span>
        <div class="outcome-item__content">
          <strong class="outcome-item__title">Team Cohesion &amp; Trust</strong>
          <p class="outcome-item__body">A choir only works when everyone listens. Your team will experience collective attention, mutual dependence, and shared achievement in a way no breakout room can replicate.</p>
        </div>
      </li>
      <li class="outcome-item reveal">
        <span class="outcome-item__line" aria-hidden="true"></span>
        <span class="outcome-item__num">03</span>
        <div class="outcome-item__content">
          <strong class="outcome-item__title">Presence &amp; Confidence</strong>
          <p class="outcome-item__body">There is nowhere to hide on the podium. Conducting a professional choir requires total physical and psychological commitment — and rewards it with immediate, audible results.</p>
        </div>
      </li>
      <li class="outcome-item reveal">
        <span class="outcome-item__line" aria-hidden="true"></span>
        <span class="outcome-item__num">04</span>
        <div class="outcome-item__content">
          <strong class="outcome-item__title">Wellbeing &amp; Stress Relief</strong>
          <p class="outcome-item__body">Choral singing is clinically evidenced to reduce cortisol and improve mood. Your team won't just learn together — they'll feel better for it.</p>
        </div>
      </li>
    </ul>
  </section>

  <!-- Stave divider -->
  <svg class="stave-divider" viewBox="0 0 1440 64" preserveAspectRatio="none" aria-hidden="true">
    <line x1="0" y1="20" x2="1440" y2="20" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="28" x2="1440" y2="28" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="36" x2="1440" y2="36" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="44" x2="1440" y2="44" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="52" x2="1440" y2="52" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
  </svg>

  <!-- ============================================================
       FEATURED ASYMMETRIC  —  mf (mezzo-forte: medium)
  ============================================================ -->
  <section class="section featured-section" style="background: var(--navy);">
    <div class="featured-grid container">
      <!-- Left: image with cyan offset square -->
      <div class="featured__image-wrap">
        <div class="featured__image-offset" aria-hidden="true"></div>
        <div class="featured__image-box">
          <VideoEmbed />
        </div>
      </div>

      <!-- Right: editorial text -->
      <div class="featured__text">
        <span class="dynamic-mark" style="color: var(--sage);">mf</span>
        <span class="featured__label">The Alma Consort</span>
        <h2 class="featured__heading">The instrument your leaders will conduct.</h2>
        <p class="featured__body">A professional London choir. Thirty voices trained to an orchestral standard. They have performed at the Barbican, the Wigmore Hall, and BBC Proms. When your leaders step onto the podium, they are conducting the real thing.</p>
        <a href="/about/" class="featured__link">
          Learn about the ensemble
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="16" height="16" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Stave divider (on navy bg) -->
  <svg class="stave-divider" viewBox="0 0 1440 64" preserveAspectRatio="none" aria-hidden="true" style="background: var(--navy);">
    <line x1="0" y1="20" x2="1440" y2="20" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="28" x2="1440" y2="28" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="36" x2="1440" y2="36" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="44" x2="1440" y2="44" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="52" x2="1440" y2="52" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
  </svg>

  <!-- ============================================================
       TESTIMONIALS  —  ff (fortissimo: loud)
  ============================================================ -->
  <section class="section testimonial-section" aria-label="Client testimonials">
    <div class="testimonial-quotemark" aria-hidden="true">&ldquo;</div>
    <div class="container">
      <span class="dynamic-mark" style="color: var(--sage);">ff</span>
      <TestimonialCarousel />
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    position: relative;
    min-height: 100vh;
    background-color: var(--navy);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 3rem;
  }

  /* Ambient orbs */
  .hero__orb {
    position: absolute;
    width: 384px;
    height: 384px;
    border-radius: 50%;
    pointer-events: none;
    animation: float 6s ease-in-out infinite;
  }

  .hero__orb--sage {
    background-color: #b7c6c2;
    filter: blur(120px);
    opacity: 0.15;
    top: 15%;
    left: -10%;
    animation-delay: 0s;
  }

  .hero__orb--blue {
    background-color: #bbe2f5;
    filter: blur(120px);
    opacity: 0.15;
    bottom: 20%;
    right: -8%;
    animation-delay: 3s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }

  /* Conducting arc */
  .hero__arc {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 60vw;
    height: auto;
    opacity: 0.25;
    pointer-events: none;
  }

  /* Text block */
  .hero__text {
    position: relative;
    z-index: 1;
    padding: 0 6vw;
    margin-bottom: auto;
    padding-top: calc(var(--nav-height) + 4rem);
  }

  .hero__line {
    font-family: var(--font-display);
    font-size: clamp(4rem, 18vw, 18vw);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    display: block;
  }

  .hero__line--solid {
    color: var(--white);
  }

  .hero__line--outline {
    -webkit-text-stroke: 1px #b7c6c2;
    color: transparent;
    margin-left: 2vw; /* staircase offset */
  }

  /* Bottom row */
  .hero__bottom {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 0 6vw 0;
    margin-top: 4rem;
  }

  .hero__tagline {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--taupe);
    max-width: 280px;
    margin: 0;
  }

  .hero__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 0.5px solid var(--sage);
    border-radius: 50%;
    color: var(--sage);
    flex-shrink: 0;
    animation: bounce 1.4s ease-in-out infinite;
    transition: background-color 300ms ease, color 300ms ease;
  }

  .hero__arrow:hover {
    background-color: var(--sage);
    color: var(--navy);
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ============================================================
     STAVE DIVIDER
  ============================================================ */
  .stave-divider {
    display: block;
    width: 100%;
    height: 64px;
  }

  /* ============================================================
     PREMISE SECTION
  ============================================================ */
  .premise-section {
    padding: 6rem 0;
  }

  .premise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  .premise__body {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--navy);
    max-width: 560px;
    margin-bottom: 1.5rem;
  }

  .premise__body--secondary {
    color: var(--taupe);
  }

  .premise__stat {
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 6rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 1rem;
  }

  .premise__stat-caption {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--taupe);
    max-width: 380px;
    margin: 0;
  }

  @media (min-width: 768px) {
    .premise-grid {
      grid-template-columns: 5fr 7fr;
      gap: 6rem;
      align-items: start;
    }
  }

  /* ============================================================
     OUTCOMES SECTION
  ============================================================ */
  .outcomes-section {
    padding: 6rem 0;
  }

  .outcomes-heading-wrap {
    padding: 0 6vw;
    margin-bottom: 0;
  }

  .outcomes-mark {
    margin-bottom: 0.5rem;
  }

  .outcomes-heading {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7rem, 7rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 2rem;
  }

  .outcomes-rule {
    display: block;
    border: none;
    border-top: 0.5px solid rgba(23, 30, 25, 0.15);
    margin: 0;
  }

  .outcomes-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .outcome-item {
    display: grid;
    grid-template-columns: 40px auto 1fr;
    gap: 1.5rem;
    align-items: start;
    padding: 2.5rem 6vw;
    border-bottom: 0.5px solid rgba(23, 30, 25, 0.1);
    transition: border-color 300ms ease;
  }

  .outcome-item:hover {
    border-bottom-color: rgba(23, 30, 25, 0.25);
  }

  .outcome-item__line {
    display: block;
    height: 0.5px;
    background-color: var(--navy);
    margin-top: 0.65rem;
    width: 40px;
    transition: width 400ms var(--ease-out);
    flex-shrink: 0;
  }

  .outcome-item:hover .outcome-item__line {
    width: 72px;
  }

  .outcome-item__num {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--navy);
    padding-top: 0.05rem;
    white-space: nowrap;
  }

  .outcome-item__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  .outcome-item__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--navy);
    letter-spacing: 0;
    text-transform: none;
  }

  .outcome-item__body {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 300;
    color: var(--taupe);
    line-height: 1.65;
    margin: 0;
  }

  @media (min-width: 768px) {
    .outcome-item {
      grid-template-columns: 40px auto 1fr;
    }

    .outcome-item__content {
      grid-template-columns: 280px 1fr;
      gap: 3rem;
      align-items: start;
    }
  }

  /* ============================================================
     FEATURED ASYMMETRIC SECTION
  ============================================================ */
  .featured-section {
    padding: 6rem 0;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }

  .featured__image-wrap {
    position: relative;
    padding-top: 48px;
    padding-left: 48px;
  }

  .featured__image-offset {
    position: absolute;
    top: 0;
    left: 0;
    width: calc(100% - 48px);
    height: calc(100% - 48px);
    background-color: #d5f4f9;
    opacity: 0.15;
  }

  .featured__image-box {
    position: relative;
    z-index: 1;
    filter: grayscale(80%);
    aspect-ratio: 4/3;
    overflow: hidden;
    background-color: #302b2f;
  }

  .featured__image-box :global(*) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 1.25rem;
  }

  .featured__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4rem, 4rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 1.75rem;
  }

  .featured__body {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--taupe);
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .featured__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--sage);
    text-decoration: none;
    transition: color 600ms var(--ease-out), transform 600ms var(--ease-out);
  }

  .featured__link:hover {
    color: var(--white);
    transform: translateX(4px);
  }

  .featured__link svg {
    display: inline-block;
    transition: transform 600ms var(--ease-out);
  }

  .featured__link:hover svg {
    transform: translateX(4px);
  }

  @media (min-width: 900px) {
    .featured-grid {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
  }

  /* ============================================================
     TESTIMONIALS SECTION
  ============================================================ */
  .testimonial-section {
    background-color: var(--charcoal);
    position: relative;
    padding: 8rem 0;
    overflow: hidden;
  }

  .testimonial-quotemark {
    position: absolute;
    top: -2rem;
    left: 3vw;
    font-family: var(--font-display);
    font-size: clamp(12rem, 28rem, 28rem);
    line-height: 1;
    color: var(--navy);
    opacity: 0.25;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .testimonial-section .container {
    position: relative;
    z-index: 1;
  }
</style>
