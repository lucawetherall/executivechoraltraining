---
import BaseLayout from '../layouts/BaseLayout.astro';
import OutcomeTile from '../components/OutcomeTile.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import CtaBand from '../components/CtaBand.astro';

const leadershipIcon = `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><path d="M24 4v20M14 14l10 10 10-10M8 34h32M12 40h24"/></svg>`;
const teamIcon = `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><circle cx="16" cy="16" r="6"/><circle cx="32" cy="16" r="6"/><circle cx="24" cy="32" r="6"/><path d="M10 28a12 12 0 0 1 28 0"/></svg>`;
const presenceIcon = `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><circle cx="24" cy="20" r="8"/><path d="M8 44c0-8.837 7.163-16 16-16s16 7.163 16 16"/><path d="M24 4v4M36 8l-3 3M40 20h-4"/></svg>`;
const wellbeingIcon = `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><path d="M24 42s-16-10-16-22a10 10 0 0 1 16-8 10 10 0 0 1 16 8c0 12-16 22-16 22z"/></svg>`;
---

<BaseLayout
  title="Executive Choral Conducting Training — Feel What Leadership Sounds Like"
  description="Choral conducting training that builds presence, communication, and trust — delivered by a professional choir. Corporate leadership development by ECCT."
>
  <!-- Hero -->
  <section class="hero">
    <!-- Stave decoration -->
    <div class="hero__stave" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>

    <div class="hero__content container">
      <p class="hero__eyebrow">Executive Choral Conducting Training</p>
      <h1>Teach your<br/>leaders to<br/>conduct.</h1>
      <p class="hero__sub">Choral conducting training that builds presence, communication, and trust — delivered by the Alma Consort, a professional London choir.</p>
      <div class="hero__ctas">
        <a href="/contact/#booking" class="btn btn--primary">Book a Free Consultation</a>
        <a href="/packages/" class="btn btn--secondary">See Our Packages</a>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- Problem / Opportunity -->
  <section class="section section--statement">
    <div class="container">
      <div class="statement-block">
        <div class="statement-block__left">
          <span class="section-label">The Premise</span>
          <p class="statement-block__headline">Most leadership training talks about communication. Ours makes you do it.</p>
        </div>
        <div class="statement-block__right">
          <p>You stand in front of a professional choir. No slides, no scripts, no jargon. Just your hands, your breath, and your intent. The music responds to your leadership in real time — honestly, immediately, and without compromise.</p>
          <p>Get the gesture right and thirty voices lock together. Hesitate, and you hear it. This is not a metaphor for leadership. It is leadership, stripped to its essentials.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Four Outcomes -->
  <section class="section section--light">
    <div class="container">
      <div class="outcomes-header text-center">
        <span class="section-label">What You'll Develop</span>
        <h2>Four outcomes. One afternoon.</h2>
      </div>
      <div class="grid-2 outcomes-grid">
        <OutcomeTile
          number="01"
          heading="Leadership & Communication"
          description="Learn to lead without speaking. Conducting demands that every instruction is clear, intentional, and legible to an ensemble watching your every move."
          icon={leadershipIcon}
        />
        <OutcomeTile
          number="02"
          heading="Team Cohesion & Trust"
          description="A choir only works when everyone listens. Your team will experience collective attention, mutual dependence, and shared achievement in a way no breakout room can replicate."
          icon={teamIcon}
        />
        <OutcomeTile
          number="03"
          heading="Presence & Confidence"
          description="There is nowhere to hide on the podium. Conducting a professional choir requires total physical and psychological commitment — and rewards it with immediate, audible results."
          icon={presenceIcon}
        />
        <OutcomeTile
          number="04"
          heading="Wellbeing & Stress Relief"
          description="Choral singing is clinically evidenced to reduce cortisol and improve mood. Your team won't just learn together — they'll feel better for it."
          icon={wellbeingIcon}
        />
      </div>
    </div>
  </section>

  <!-- Video Feature -->
  <section class="section section--video">
    <div class="container">
      <div class="video-intro text-center">
        <span class="section-label">In Performance</span>
        <h2>Meet the Alma Consort.</h2>
        <p class="video-intro__sub">Our resident professional choir. The instrument your leaders will conduct.</p>
      </div>
      <VideoEmbed caption="The Alma Consort in performance." />
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center" style="margin-bottom: 3rem;">
        <span class="section-label">What Clients Say</span>
      </div>
      <div class="logos-bar">
        <div class="logos-bar__placeholder">Client logos</div>
      </div>
      <TestimonialCarousel />
    </div>
  </section>

  <!-- Final CTA -->
  <CtaBand
    label="Get Started"
    headline="Your first session is free."
    body="We offer a complimentary conducting consultation with an Oxford University music tutor. No commitment, no cost — just a conversation about what this could do for your team."
    buttonText="Book Now"
    buttonLink="/contact/#booking"
  />
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse 70% 100% at 85% 50%, rgba(201, 168, 76, 0.06) 0%, transparent 65%),
      linear-gradient(160deg, #0D1A2F 0%, #132238 60%, #1B2A4A 100%);
    overflow: hidden;
  }

  /* Musical stave lines decoration */
  .hero__stave {
    position: absolute;
    right: 6%;
    top: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    width: 160px;
    pointer-events: none;
  }

  .hero__stave span {
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.07), transparent);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    color: var(--white);
    padding: 8rem 1.5rem 5rem;
    max-width: 680px;
  }

  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.9;
    margin-bottom: 1.5rem;
  }

  .hero__content h1 {
    color: var(--white);
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 1.75rem;
  }

  .hero__sub {
    font-size: 1.1rem;
    max-width: 480px;
    margin-bottom: 2.75rem;
    opacity: 0.75;
    line-height: 1.75;
  }

  .hero__ctas {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    align-items: flex-start;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.4);
    z-index: 1;
  }

  .hero__scroll-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .hero__scroll-line {
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.4), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 0.8; transform: scaleY(1.1); }
  }

  /* ===== Statement / Problem Section ===== */
  .statement-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 1040px;
    margin: 0 auto;
  }

  .statement-block__headline {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.1rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--navy);
    margin: 0;
  }

  .statement-block__right {
    color: var(--mid-grey);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .statement-block__right p {
    margin-bottom: 1.25rem;
  }

  .statement-block__right p:last-child {
    margin-bottom: 0;
  }

  /* ===== Outcomes ===== */
  .outcomes-header {
    margin-bottom: 4rem;
  }

  .outcomes-header h2 {
    margin-top: 0.5rem;
  }

  .outcomes-grid {
    gap: 0;
  }

  /* ===== Video section ===== */
  .video-intro {
    margin-bottom: 3rem;
  }

  .video-intro h2 {
    margin-top: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .video-intro__sub {
    color: var(--mid-grey);
    font-size: 1.05rem;
    max-width: 420px;
    margin: 0 auto;
  }

  /* ===== Logos bar ===== */
  .logos-bar {
    margin-bottom: 4rem;
  }

  .logos-bar__placeholder {
    text-align: center;
    padding: 1.75rem;
    border: 1px dashed rgba(27, 42, 74, 0.2);
    border-radius: 3px;
    color: var(--mid-grey);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  @media (min-width: 640px) {
    .hero__ctas {
      flex-direction: row;
      align-items: center;
    }
  }

  @media (min-width: 768px) {
    .statement-block {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
  }
</style>
