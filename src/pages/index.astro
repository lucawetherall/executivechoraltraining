---
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
---

<BaseLayout
  title="Executive Choral Conducting Training — Feel What Leadership Sounds Like"
  description="Choral conducting training that builds presence, communication, and trust — delivered by a professional choir. Corporate leadership development by ECCT."
>

  <!-- ============================================================
       HERO — Lamoon-style: centered badge + split headline + dual CTAs
  ============================================================ -->
  <section class="hero" aria-label="Hero">
    <!-- Background ambient orbs -->
    <div class="hero__orb hero__orb--sage" aria-hidden="true"></div>
    <div class="hero__orb hero__orb--blue" aria-hidden="true"></div>

    <!-- Conducting arc SVG -->
    <svg class="hero__arc" viewBox="0 0 1000 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
      <path d="M 0 220 Q 500 20 1000 220" stroke="#b7c6c2" stroke-width="1" fill="none"/>
    </svg>

    <!-- Badge pill -->
    <div class="hero__badge" aria-label="Tagline badge">
      <span class="hero__badge-dot" aria-hidden="true"></span>
      <span>London's Premier Leadership Experience</span>
    </div>

    <!-- Main headline -->
    <div class="hero__headline" aria-label="Site headline">
      <p class="hero__line hero__line--solid">TEACH YOUR</p>
      <p class="hero__line hero__line--outline">LEADERS.</p>
    </div>

    <!-- Subtext + CTAs -->
    <div class="hero__body">
      <p class="hero__tagline">Choral conducting training that builds presence, communication, and trust — delivered by the Alma Consort, a professional London choir.</p>
      <div class="hero__ctas">
        <a href="/contact/#booking" class="btn btn--primary hero__cta">Book a Session</a>
        <a href="/what-we-do/" class="hero__cta-ghost">
          See how it works
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Floating stat card -->
    <div class="hero__stat-card" aria-label="Key statistic">
      <span class="hero__stat-num">30</span>
      <span class="hero__stat-label">professional voices<br/>respond in real time</span>
    </div>

    <!-- Scroll indicator -->
    <a href="#trust" class="hero__scroll" aria-label="Scroll down">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="18" height="18">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </a>
  </section>

  <!-- ============================================================
       TRUST TICKER — marquee of credentials
  ============================================================ -->
  <section class="trust-strip" id="trust" aria-label="Credentials">
    <div class="trust-strip__track" aria-hidden="true">
      <div class="trust-strip__items">
        <span>FTSE 100 Teams</span>
        <span class="trust-strip__sep">·</span>
        <span>The Barbican</span>
        <span class="trust-strip__sep">·</span>
        <span>Wigmore Hall</span>
        <span class="trust-strip__sep">·</span>
        <span>BBC Proms</span>
        <span class="trust-strip__sep">·</span>
        <span>Senior Leadership Away-Days</span>
        <span class="trust-strip__sep">·</span>
        <span>Conference Keynotes</span>
        <span class="trust-strip__sep">·</span>
        <span>Board Retreats</span>
        <span class="trust-strip__sep">·</span>
        <span>Graduate Programmes</span>
        <span class="trust-strip__sep">·</span>
        <!-- Duplicate for seamless loop -->
        <span>FTSE 100 Teams</span>
        <span class="trust-strip__sep">·</span>
        <span>The Barbican</span>
        <span class="trust-strip__sep">·</span>
        <span>Wigmore Hall</span>
        <span class="trust-strip__sep">·</span>
        <span>BBC Proms</span>
        <span class="trust-strip__sep">·</span>
        <span>Senior Leadership Away-Days</span>
        <span class="trust-strip__sep">·</span>
        <span>Conference Keynotes</span>
        <span class="trust-strip__sep">·</span>
        <span>Board Boards</span>
        <span class="trust-strip__sep">·</span>
        <span>Graduate Programmes</span>
        <span class="trust-strip__sep">·</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PREMISE — pp: quiet, editorial
  ============================================================ -->
  <section class="section premise-section">
    <div class="container premise-grid">
      <div class="premise__left">
        <span class="dynamic-mark">pp</span>
        <h2 class="premise__heading">Most leadership training talks about communication.<br/>Ours makes you do it.</h2>
      </div>
      <div class="premise__right">
        <p class="premise__body">You stand in front of a professional choir. No slides, no scripts, no jargon. Just your hands, your breath, and your intent.</p>
        <p class="premise__body premise__body--muted">The music responds to your leadership in real time — honestly, immediately, and without compromise. A choir of voices that cannot lie.</p>
        <a href="/what-we-do/" class="premise__link">
          Explore the method
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       STATS ROW — 3 key numbers
  ============================================================ -->
  <section class="stats-section" aria-label="Key statistics">
    <div class="container stats-grid">
      <div class="stat-item reveal">
        <span class="stat-item__num">6</span>
        <span class="stat-item__label">Minimum number of choral practitioners in the room to facilitate an unforgettable experience</span>
      </div>
      <div class="stat-item reveal">
        <span class="stat-item__num">4</span>
        <span class="stat-item__label">Programme tiers from taster to immersion</span>
      </div>
      <div class="stat-item reveal">
        <span class="stat-item__num">2h</span>
        <span class="stat-item__label">Minimum time to transform how you lead</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       OUTCOMES BENTO — mp: features in a bento grid
  ============================================================ -->
  <section class="section outcomes-section">
    <div class="container">
      <div class="outcomes-header">
        <span class="dynamic-mark">mp</span>
        <h2 class="outcomes-heading">What<br/>Changes.</h2>
        <p class="outcomes-sub">Four things that shift every time a leader steps onto the podium.</p>
      </div>

      <div class="bento-grid">
        <!-- Large card -->
        <article class="bento-card bento-card--large reveal">
          <span class="bento-card__num">01</span>
          <div class="bento-card__body">
            <h3 class="bento-card__title">Leadership &amp; Communication</h3>
            <p class="bento-card__text">Learn to lead without speaking. Conducting demands that every instruction is clear, intentional, and legible to an ensemble watching your every move. What you think you're saying and what the choir hears are rarely the same — until they are.</p>
          </div>
          <div class="bento-card__tag">Core Skill</div>
        </article>

        <!-- Medium card -->
        <article class="bento-card bento-card--medium reveal">
          <span class="bento-card__num">02</span>
          <div class="bento-card__body">
            <h3 class="bento-card__title">Team Cohesion &amp; Trust</h3>
            <p class="bento-card__text">A choir only works when everyone listens. Your team will experience collective attention and shared achievement in a way no breakout room can replicate.</p>
          </div>
          <div class="bento-card__tag">Team</div>
        </article>

        <!-- Small card -->
        <article class="bento-card bento-card--small reveal">
          <span class="bento-card__num">03</span>
          <div class="bento-card__body">
            <h3 class="bento-card__title">Presence &amp; Confidence</h3>
            <p class="bento-card__text">There is nowhere to hide on the podium. Conducting a professional choir requires total physical and psychological commitment.</p>
          </div>
          <div class="bento-card__tag">Presence</div>
        </article>

        <!-- Small card -->
        <article class="bento-card bento-card--small reveal">
          <span class="bento-card__num">04</span>
          <div class="bento-card__body">
            <h3 class="bento-card__title">Wellbeing &amp; Stress Relief</h3>
            <p class="bento-card__text">Participating in choral music is clinically evidenced to reduce cortisol and improve mood. Your team won't just learn — they'll feel better for it.</p>
          </div>
          <div class="bento-card__tag">Wellbeing</div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURED ENSEMBLE — mf: asymmetric video + text (navy bg)
  ============================================================ -->
  <section class="section featured-section">
    <div class="featured-grid container">
      <!-- Left: image with offset accent -->
      <div class="featured__image-wrap reveal">
        <div class="featured__image-offset" aria-hidden="true"></div>
        <div class="featured__image-box">
          <VideoEmbed src="https://www.youtube.com/embed/GjNdZVs7g68" />
        </div>
      </div>

      <!-- Right: editorial text -->
      <div class="featured__text">
        <span class="dynamic-mark" style="color: var(--sage);">mf</span>
        <span class="featured__label">The Alma Consort</span>
        <h2 class="featured__heading">The instrument your leaders will conduct.</h2>
        <p class="featured__body">A professional London choir. Thirty voices trained to an orchestral standard. They have performed at the Barbican, the Wigmore Hall, and BBC Proms. When your leaders step onto the podium, they are conducting the real thing.</p>
        <a href="/about/" class="featured__link">
          Learn about the ensemble
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TESTIMONIALS — ff: 3-card grid
  ============================================================ -->
  <section class="section testimonials-section" aria-label="Client testimonials">
    <div class="container">
      <div class="testimonials-header">
        <span class="dynamic-mark" style="color: var(--sage);">ff</span>
        <h2 class="testimonials-heading">Heard from<br/>the podium.</h2>
      </div>

      <div class="testimonials-grid">
        <blockquote class="t-card reveal">
          <div class="t-card__quote-mark" aria-hidden="true">&ldquo;</div>
          <p class="t-card__text">We've run every kind of team-building exercise imaginable. This was the first time I saw our entire senior leadership team genuinely out of their comfort zone — and genuinely better for it.</p>
          <footer class="t-card__footer">
            <div class="t-card__avatar" aria-hidden="true">HP</div>
            <div>
              <strong class="t-card__name">[Name]</strong>
              <span class="t-card__role">Head of People, [Company]</span>
            </div>
          </footer>
        </blockquote>

        <blockquote class="t-card reveal">
          <div class="t-card__quote-mark" aria-hidden="true">&ldquo;</div>
          <p class="t-card__text">I didn't expect to learn more about my communication style in two hours with a choir than I did in a year of executive coaching. The feedback from the music is instant and unambiguous.</p>
          <footer class="t-card__footer">
            <div class="t-card__avatar" aria-hidden="true">MD</div>
            <div>
              <strong class="t-card__name">[Name]</strong>
              <span class="t-card__role">Managing Director, [Company]</span>
            </div>
          </footer>
        </blockquote>

        <blockquote class="t-card reveal">
          <div class="t-card__quote-mark" aria-hidden="true">&ldquo;</div>
          <p class="t-card__text">Our team still talks about it six months later. Not as a fun day — as a turning point in how we work together.</p>
          <footer class="t-card__footer">
            <div class="t-card__avatar" aria-hidden="true">LM</div>
            <div>
              <strong class="t-card__name">[Name]</strong>
              <span class="t-card__role">L&D Manager, [Company]</span>
            </div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INSIGHTS PREVIEW — editorial blog grid
  ============================================================ -->
  <section class="section insights-section">
    <div class="container">
      <div class="insights-header">
        <div>
          <span class="section-label">Insights</span>
          <h2 class="insights-heading">From the<br/>music stand.</h2>
        </div>
        <a href="/insights/" class="insights-all">
          All articles
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="insights-grid">
        <a href="/insights/what-conductors-know/" class="insight-card reveal">
          <span class="insight-card__tag">Leadership</span>
          <h3 class="insight-card__title">What conductors know about leadership that business schools don't</h3>
          <p class="insight-card__excerpt">The podium as a laboratory for executive presence, trust, and real-time feedback.</p>
          <span class="insight-card__arrow">→</span>
        </a>

        <a href="/insights/science-of-singing/" class="insight-card reveal">
          <span class="insight-card__tag">Wellbeing</span>
          <h3 class="insight-card__title">The science of singing: why group music-making rewires the team</h3>
          <p class="insight-card__excerpt">Oxytocin, cortisol, and the neurological case for bringing a choir into your leadership programme.</p>
          <span class="insight-card__arrow">→</span>
        </a>

        <a href="/insights/team-away-day-choir/" class="insight-card reveal">
          <span class="insight-card__tag">Away Days</span>
          <h3 class="insight-card__title">Why your next team away-day should end with a performance</h3>
          <p class="insight-card__excerpt">The case for shared creative risk as the antidote to formulaic corporate offsites.</p>
          <span class="insight-card__arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND — bold navy closing section
  ============================================================ -->
  <section class="cta-close" aria-label="Call to action">
    <div class="cta-close__inner container">
      <div class="cta-close__text">
        <span class="dynamic-mark" style="color: var(--sage); opacity: 0.6;">fff</span>
        <h2 class="cta-close__heading">Ready to lead?</h2>
        <p class="cta-close__body">Book a free thirty-minute consultation with our music director and experience the podium for yourself.</p>
      </div>
      <div class="cta-close__actions">
        <a href="/contact/#booking" class="btn btn--primary">Book a Free Consultation</a>
        <a href="/packages/" class="cta-close__ghost">View Packages →</a>
      </div>
    </div>
    <!-- Stave lines as background texture -->
    <svg class="cta-close__stave" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <line x1="0" y1="30" x2="1440" y2="30" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
      <line x1="0" y1="50" x2="1440" y2="50" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
      <line x1="0" y1="70" x2="1440" y2="70" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
      <line x1="0" y1="90" x2="1440" y2="90" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
      <line x1="0" y1="110" x2="1440" y2="110" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
    </svg>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    position: relative;
    min-height: 100vh;
    background-color: var(--navy);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + 4rem) 6vw 4rem;
    text-align: center;
    gap: 2rem;
  }

  .hero__orb {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    pointer-events: none;
    animation: float 8s ease-in-out infinite;
  }

  .hero__orb--sage {
    background-color: #b7c6c2;
    filter: blur(130px);
    opacity: 0.12;
    top: 10%;
    left: -8%;
    animation-delay: 0s;
  }

  .hero__orb--blue {
    background-color: #bbe2f5;
    filter: blur(130px);
    opacity: 0.12;
    bottom: 15%;
    right: -6%;
    animation-delay: 4s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-24px); }
  }

  .hero__arc {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: auto;
    opacity: 0.18;
    pointer-events: none;
  }

  /* Badge */
  .hero__badge {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border: 0.5px solid rgba(183, 198, 194, 0.3);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage);
    background: rgba(183, 198, 194, 0.06);
    backdrop-filter: blur(8px);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--sage);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* Headline */
  .hero__headline {
    position: relative;
    z-index: 1;
  }

  .hero__line {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 16vw, 16vw);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    display: block;
  }

  .hero__line--solid {
    color: var(--white);
  }

  .hero__line--outline {
    -webkit-text-stroke: 1px #b7c6c2;
    color: transparent;
  }

  /* Body / CTAs */
  .hero__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 560px;
  }

  .hero__tagline {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--taupe);
    margin: 0;
  }

  .hero__ctas {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__cta {
    padding: 12px 28px;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
  }

  .hero__cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--sage);
    text-decoration: none;
    transition: gap 400ms var(--ease-out), opacity 400ms ease;
  }

  .hero__cta-ghost:hover {
    gap: 0.75rem;
    opacity: 0.8;
  }

  /* Floating stat card */
  .hero__stat-card {
    position: absolute;
    bottom: 5rem;
    right: 6vw;
    z-index: 2;
    padding: 1.25rem 1.75rem;
    background: rgba(183, 198, 194, 0.08);
    border: 0.5px solid rgba(183, 198, 194, 0.2);
    backdrop-filter: blur(12px);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: left;
  }

  .hero__stat-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--white);
  }

  .hero__stat-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 300;
    line-height: 1.4;
    color: var(--sage);
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 0.5px solid rgba(183, 198, 194, 0.3);
    border-radius: 50%;
    color: var(--sage);
    animation: bounce 1.6s ease-in-out infinite;
    transition: background-color 300ms ease;
  }

  .hero__scroll:hover {
    background-color: rgba(183, 198, 194, 0.1);
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(5px); }
  }

  @media (max-width: 767px) {
    .hero__stat-card {
      display: none;
    }
  }

  /* ============================================================
     TRUST TICKER
  ============================================================ */
  .trust-strip {
    background-color: var(--navy);
    border-top: 0.5px solid rgba(183, 198, 194, 0.1);
    border-bottom: 0.5px solid rgba(183, 198, 194, 0.1);
    padding: 1rem 0;
    overflow: hidden;
  }

  .trust-strip__track {
    overflow: hidden;
  }

  .trust-strip__items {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    white-space: nowrap;
    animation: ticker 28s linear infinite;
    will-change: transform;
  }

  .trust-strip__items span {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.6;
    flex-shrink: 0;
  }

  .trust-strip__sep {
    color: var(--sage) !important;
    opacity: 0.3 !important;
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ============================================================
     PREMISE
  ============================================================ */
  .premise-section {
    padding: 7rem 0;
  }

  .premise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .premise__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--navy);
    margin-top: 0.75rem;
  }

  .premise__body {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--navy);
    margin-bottom: 1.25rem;
    max-width: 480px;
  }

  .premise__body--muted {
    color: var(--taupe);
  }

  .premise__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--navy);
    text-decoration: none;
    border-bottom: 0.5px solid rgba(23,30,25,0.25);
    padding-bottom: 2px;
    transition: border-color 300ms ease, gap 300ms ease;
    margin-top: 0.5rem;
  }

  .premise__link:hover {
    border-color: var(--navy);
    gap: 0.75rem;
  }

  @media (min-width: 900px) {
    .premise-grid {
      grid-template-columns: 5fr 7fr;
      gap: 6rem;
      align-items: start;
    }
  }

  /* ============================================================
