---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Executive Choral Conducting Training"
  description="Book a free conducting consultation or send us an enquiry. Get in touch to discuss how choral conducting can transform your team's leadership."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Contact us.</h1>
      <p>Book a consultation or send an enquiry — we'd love to hear from you.</p>
    </div>
  </section>

  <!-- Two-column layout -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Left: Enquiry Form -->
        <div class="contact-form-wrapper">
          <h2>Send an enquiry</h2>
          <form action="https://api.web3forms.com/submit" method="POST" class="contact-form" id="contact-form">
            <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
            <input type="hidden" name="subject" value="New ECT Enquiry" />
            <input type="hidden" name="from_name" value="ECT Website" />

            <div class="form-group">
              <label for="name">Name *</label>
              <input type="text" id="name" name="name" required />
            </div>

            <div class="form-group">
              <label for="company">Company</label>
              <input type="text" id="company" name="company" />
            </div>

            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" />
            </div>

            <div class="form-group">
              <label for="package">Package interest</label>
              <select id="package" name="package">
                <option value="">Select a package...</option>
                <option value="Taster Session">Taster Session</option>
                <option value="Full Day">Full Day</option>
                <option value="Three-Day Programme">Three-Day Programme</option>
                <option value="Week-Long Programme">Week-Long Programme</option>
                <option value="Custom">Custom</option>
                <option value="Premium Church Venue">Premium Church Venue</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5"></textarea>
            </div>

            <button type="submit" class="btn btn--primary">Send Enquiry</button>
          </form>
        </div>

        <!-- Right: Cal.com Embed -->
        <div class="booking-wrapper" id="booking">
          <h2>Book your free consultation.</h2>
          <p class="booking-sub">A 30-minute session with our music director. No commitment, no cost — just a conversation about what conducting could do for your team.</p>
          <div id="cal-inline" style="width:100%;height:630px;overflow:auto;"></div>
          <script>
            (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar); return; } p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
            Cal("init");
            Cal("inline", { elementOrSelector: "#cal-inline", calLink: "executivechoraltraining" });
            Cal("ui", { styles: { branding: { brandColor: "#C9A84C" } } });
          </script>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Details -->
  <section class="section section--light">
    <div class="container text-center">
      <h2 class="contact-details-heading">Get in touch</h2>
      <div class="contact-details">
        <div>
          <h4>Email</h4>
          <a href="mailto:office@executivechoraltraining.com">office@executivechoraltraining.com</a>
        </div>
        <div>
          <h4>Phone</h4>
          <a href="tel:+442079460123">+44 20 7946 0123</a>
        </div>
        <div>
          <h4>Social</h4>
          <a href="https://www.linkedin.com/company/executive-choral-conducting-training/about/?viewAsMember=true" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Pre-populate package dropdown from URL parameter
  const params = new URLSearchParams(window.location.search);
  const pkg = params.get('package');
  if (pkg) {
    const select = document.getElementById('package') as HTMLSelectElement;
    if (select) {
      for (const option of select.options) {
        if (option.value === pkg) {
          option.selected = true;
          break;
        }
      }
    }
  }
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  .contact-form-wrapper h2,
  .booking-wrapper h2 {
    margin-bottom: 1rem;
  }

  .booking-sub {
    color: var(--mid-grey);
    margin-bottom: 2rem;
  }

  .cal-placeholder {
    background: var(--cream);
    border: 1px dashed rgba(23, 30, 25, 0.15);
    border-radius: 0;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cal-placeholder__inner {
    text-align: center;
    color: var(--mid-grey);
  }

  .cal-placeholder__inner svg {
    margin: 0 auto 1rem;
    opacity: 0.3;
  }

  .cal-placeholder__inner p {
    font-size: 1rem;
    font-weight: 500;
  }

  .cal-placeholder__note {
    font-size: 0.85rem;
    font-weight: 300 !important;
    opacity: 0.6;
  }

  .contact-details-heading {
    margin-bottom: 2rem;
  }

  .contact-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-details h4 {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem;
    color: var(--mid-grey);
  }

  .contact-details a {
    font-size: 1.05rem;
    color: var(--navy);
    font-weight: 500;
  }

  .contact-details a:hover {
    color: var(--gold);
  }

  .contact-details span {
    font-size: 1.05rem;
    color: var(--mid-grey);
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }

    .contact-details {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
