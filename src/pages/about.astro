---
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import TeamCard from '../components/TeamCard.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About — Executive Choral Conducting Training"
  description="We are musicians and educators who built ECCT because we saw what the conducting podium does to people who step onto it. Meet our team and our choir, the Alma Consort."
>

  <!-- ============================================================
       PAGE HEADER — navy
  ============================================================ -->
  <section class="page-header">
    <div class="container">
      <span class="section-label">ECCT</span>
      <h1>About us.</h1>
      <p>Musicians and educators who believe leadership is a physical act — and that the podium proves it.</p>
    </div>
  </section>

  <!-- ============================================================
       BRAND STORY — white, editorial two-column
  ============================================================ -->
  <section class="section story-section">
    <div class="container story-grid">
      <div class="story__left">
        <span class="dynamic-mark">p</span>
        <h2 class="story__heading">Why we built this.</h2>
      </div>
      <div class="story__right reveal">
        <p>Executive Choral Conducting Training exists because we believe leadership is a physical act. It lives in the body — in how you stand, how you breathe, how you hold attention, how you respond when things don't go as planned. Most leadership development treats these qualities as peripheral. We put them at the centre.</p>
        <p>Our method is simple. We give you a baton, a professional choir, and a piece of music. Then we ask you to lead. What happens next is more revealing, more demanding, and more rewarding than any workshop we've encountered — and we've encountered a lot of them.</p>
        <p>We are musicians and educators who have spent careers working at the highest levels of choral performance and music education. We built ECCT because we saw what the conducting podium does to people who step onto it: it clarifies something about how they lead that nothing else quite reaches.</p>
        <p class="story__muted">There is no simulation here. No role-play, no acted scenario. The choir is real, the music is real, and the response to your gesture is immediate and unambiguous. That honesty is exactly what makes it work.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VALUES — navy, bento-style grid
  ============================================================ -->
  <section class="section section--navy values-section">
    <div class="container">
      <div class="values-header">
        <span class="dynamic-mark" style="color: var(--sage); opacity: 0.6;">mp</span>
        <h2 class="values-heading">What we<br/>stand for.</h2>
        <p class="values-sub">Four principles that shape every ECCT programme.</p>
      </div>
      <div class="values-grid">
        <article class="v-card reveal">
          <span class="v-card__num">01</span>
          <h3 class="v-card__title">Honesty over comfort</h3>
          <p class="v-card__text">The podium doesn't let you hide. We design every session so that the feedback is real — not softened by politeness or obscured by abstraction. Leaders grow fastest when they can see exactly what they're doing.</p>
        </article>
        <article class="v-card reveal">
          <span class="v-card__num">02</span>
          <h3 class="v-card__title">Craft above all</h3>
          <p class="v-card__text">The quality of the ensemble matters profoundly. We work only with professional musicians whose standard is high enough to make the conducting experience credible. You cannot fool a professional choir.</p>
        </article>
        <article class="v-card reveal">
          <span class="v-card__num">03</span>
          <h3 class="v-card__title">Experience, not explanation</h3>
          <p class="v-card__text">We believe in doing rather than describing. Every insight that emerges from an ECCT session is earned on the podium, not extracted from a slide. The body learns things the mind cannot be told.</p>
        </article>
        <article class="v-card reveal">
          <span class="v-card__num">04</span>
          <h3 class="v-card__title">Rigour and joy</h3>
          <p class="v-card__text">Serious work and genuine enjoyment are not opposites. Our sessions are demanding — and they are also, consistently, among the most energising experiences participants report having in a professional context.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       OUR CHOIR — white, asymmetric video + text (mirrors landing Featured)
  ============================================================ -->
  <section class="section choir-section">
    <div class="choir-grid container">
      <!-- Left: video with offset accent -->
      <div class="choir__image-wrap reveal">
        <div class="choir__image-offset" aria-hidden="true"></div>
        <div class="choir__image-box">
          <VideoEmbed caption="The Alma Consort in performance." />
        </div>
      </div>

      <!-- Right: editorial text -->
      <div class="choir__text">
        <span class="dynamic-mark">mf</span>
        <span class="choir__label">The Alma Consort</span>
        <h2 class="choir__heading">Our choir: the instrument your leaders will conduct.</h2>
        <p class="choir__body">A dynamic, detail-oriented choral group working at the highest professional standard. The Alma Consort's singers have performed across London's foremost venues — from the Barbican and Wigmore Hall to the BBC Proms — bringing the same rigour and precision to every engagement they take on.</p>
        <p class="choir__body">That standard is what makes our sessions work. When your team steps onto the podium, they are conducting musicians who respond to exactly what they give — no more, no less. There is nowhere for ambiguity to hide, and no room for anything other than genuine leadership.</p>
        <div class="choir__credentials">
          <div class="cred">
            <span class="cred__num">100%</span>
            <span class="cred__label">Professional musicians</span>
          </div>
          <div class="cred">
            <span class="cred__num">3</span>
            <span class="cred__label">Flagship concert halls</span>
          </div>
          <div class="cred">
            <span class="cred__num">10+</span>
            <span class="cred__label">Years performing</span>
          </div>
        </div>
        <a href="https://www.almaconsort.com" target="_blank" rel="noopener noreferrer" class="choir__link">
          Visit the Alma Consort website
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       OUR TEAM — charcoal (like testimonials on landing)
  ============================================================ -->
  <section class="section team-section">
    <div class="container">
      <div class="team-header">
        <span class="dynamic-mark" style="color: var(--sage); opacity: 0.6;">ff</span>
        <h2 class="team-heading">Our team.</h2>
        <p class="team-intro">ECCT is led by two musicians with deep roots in professional choral performance, music education, and the academic study of conducting.</p>
      </div>
      <div class="grid-2 team-grid">
        <TeamCard
          name="Luca Wetherall"
          role="Music Director"
          bio="A conductor, singer, and educator based in London. Holds a Clarendon Scholarship at the University of Oxford, where they teach at the Faculty of Music and undertake doctoral research in choral conducting. Directs the Alma Consort and brings extensive experience in vocal production, ensemble direction, and music education across multiple genres to every ECCT session."
        />
        <TeamCard
          name="Izzy Mohan"
          role="Managing Director"
          bio="A pianist, conductor, and singer based in London. A graduate of the University of Oxford and the Royal Academy of Music, bringing expertise in collaborative performance, ensemble direction, and music education to ECCT's programmes. Leads the business operations and partnerships that bring ECCT to organisations across the UK."
          image={base + 'team/izzy-mohan.jpg'}
        />
      </div>
      <p class="team-footnote">Behind Luca and Izzy sits an extensive and varied creative team — designers, producers, facilitators, and musicians — who make every ECCT programme possible.</p>
    </div>
  </section>

  <!-- ============================================================
       CTA CLOSE — navy, mirrors landing CTA
  ============================================================ -->
  <section class="cta-close" aria-label="Call to action">
    <div class="cta-close__inner container">
      <div class="cta-close__text">
        <span class="dynamic-mark" style="color: var(--sage); opacity: 0.6;">fff</span>
        <h2 class="cta-close__heading">Ready to step onto the podium?</h2>
        <p class="cta-close__body">Explore our programmes or get in touch to discuss a bespoke session for your organisation.</p>
      </div>
      <div class="cta-close__actions">
        <a href={base + 'packages/'} class="btn btn--primary">View Packages</a>
        <a href={base + 'contact/#booking'} class="cta-close__ghost">Book a consultation →</a>
      </div>
    </div>
    <svg class="cta-close__stave" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <line x1="0" y1="30" x2="1440" y2="30" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
      <line x1="0" y1="50" x2="1440" y2="50" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
      <line x1="0" y1="70" x2="1440" y2="70" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
      <line x1="0" y1="90" x2="1440" y2="90" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
      <line x1="0" y1="110" x2="1440" y2="110" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
    </svg>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     BRAND STORY
  ============================================================ */
  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 900px) {
    .story-grid {
      grid-template-columns: 5fr 7fr;
      gap: 6rem;
      align-items: start;
    }
  }

  .story__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--navy);
    margin-top: 0.75rem;
  }

  .story__right p {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--navy);
    margin-bottom: 1.25rem;
  }

  .story__muted {
    color: var(--taupe) !important;
  }

  /* ============================================================
     VALUES — navy
  ============================================================ */
  .values-section {
    padding: 7rem 0;
  }

  .values-header {
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .values-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
  }

  .values-sub {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.9);
    max-width: 400px;
    margin-top: 1rem;
    line-height: 1.6;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .values-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .v-card {
    background: rgba(255, 255, 255, 0.05);
    border: 0.5px solid rgba(122, 31, 46, 0.18);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background-color 400ms ease, border-color 400ms ease;
  }

  .v-card:hover {
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(122, 31, 46, 0.35);
  }

  .v-card__num {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage);
    opacity: 0.75;
  }

  .v-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--white);
    font-weight: 400;
  }

  .v-card__text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  /* ============================================================
     CHOIR — white, asymmetric layout (mirrors Featured Ensemble)
  ============================================================ */
  .choir-section {
    padding: 7rem 0;
  }

  .choir-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .choir-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }

  .choir__image-wrap {
    position: relative;
    padding-top: 48px;
    padding-left: 48px;
  }

  .choir__image-offset {
    position: absolute;
    top: 0;
    left: 0;
    width: calc(100% - 48px);
    height: calc(100% - 48px);
    background-color: var(--sage);
    opacity: 0.18;
  }

  .choir__image-box {
    position: relative;
    z-index: 1;
    aspect-ratio: 4/3;
    overflow: hidden;
    background-color: var(--charcoal);
  }

  .choir__image-box :global(*) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .choir__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--taupe);
    margin-bottom: 1rem;
  }

  .choir__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 1.5rem;
  }

  .choir__body {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--taupe);
    max-width: 480px;
    margin-bottom: 1.25rem;
  }

  .choir__credentials {
    display: flex;
    gap: 2.5rem;
    margin: 2rem 0;
    padding-top: 2rem;
    border-top: 0.5px solid rgba(23, 30, 25, 0.08);
  }

  .cred {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cred__num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 0.88;
    letter-spacing: -0.03em;
    color: var(--navy);
  }

  .cred__label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 300;
    line-height: 1.4;
    color: var(--taupe);
  }

  .choir__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--navy);
    text-decoration: none;
    border-bottom: 0.5px solid rgba(23, 30, 25, 0.25);
    padding-bottom: 2px;
    transition: border-color 300ms ease, gap 300ms ease;
  }

  .choir__link:hover {
    border-color: var(--navy);
    gap: 0.75rem;
  }

  /* ============================================================
     TEAM — charcoal (mirrors testimonials section on landing)
  ============================================================ */
  .team-section {
    background-color: var(--charcoal);
    padding: 7rem 0;
  }

  .team-header {
    margin-bottom: 3.5rem;
  }

  .team-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
    margin-top: 0.5rem;
  }

  .team-intro {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
    max-width: 480px;
    margin-top: 1rem;
  }

  /* Override TeamCard borders/colors for charcoal background */
  .team-section :global(.team-card) {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  .team-section :global(.team-card h3) {
    color: var(--white);
  }

  .team-section :global(.team-card__bio) {
    color: rgba(255, 255, 255, 0.85);
  }

  .team-grid {
    max-width: 860px;
  }

  .team-footnote {
    max-width: 560px;
    margin-top: 3rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ============================================================
     CTA CLOSE — navy, mirrors landing CTA
  ============================================================ */
  .cta-close {
    background-color: var(--navy);
    padding: 7rem 0;
    position: relative;
    overflow: hidden;
  }

  .cta-close__inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    position: relative;
    z-index: 1;
  }

  .cta-close__heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
    margin-top: 0.5rem;
  }

  .cta-close__body {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
    max-width: 480px;
    margin-top: 0.5rem;
  }

  .cta-close__actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-close__ghost {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
    opacity: 0.85;
    text-decoration: none;
    transition: opacity 300ms ease;
  }

  .cta-close__ghost:hover {
    opacity: 1;
  }

  .cta-close__stave {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  @media (min-width: 900px) {
    .cta-close__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .cta-close__text {
      max-width: 640px;
    }

    .cta-close__actions {
      flex-direction: column;
      align-items: flex-start;
      flex-shrink: 0;
    }
  }
</style>
