---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="What We Do — Executive Choral Conducting Training"
  description="Why conducting trains leaders better than talking about leadership. Discover our method: non-verbal communication, real-time feedback, and genuine team cohesion."
>

  <!-- ============================================================
       HERO — navy bg, Anton headline split solid/outline
  ============================================================ -->
  <section class="wwd-hero" aria-label="Page hero">
    <div class="wwd-hero__orb wwd-hero__orb--sage" aria-hidden="true"></div>
    <div class="wwd-hero__orb wwd-hero__orb--blue" aria-hidden="true"></div>

    <svg class="wwd-hero__arc" viewBox="0 0 1000 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
      <path d="M 0 220 Q 500 20 1000 220" stroke="#A3344A" stroke-width="1" fill="none"/>
    </svg>

    <div class="wwd-hero__badge" aria-label="Page label">
      <span class="wwd-hero__badge-dot" aria-hidden="true"></span>
      <span>Our Approach</span>
    </div>

    <div class="wwd-hero__headline" aria-label="Page headline">
      <p class="wwd-hero__line wwd-hero__line--solid">THE</p>
      <p class="wwd-hero__line wwd-hero__line--outline">METHOD.</p>
    </div>

    <div class="wwd-hero__body">
      <p class="wwd-hero__tagline">Why conducting trains leaders better than talking about leadership.</p>
      <div class="wwd-hero__ctas">
        <a href={base + 'contact/#booking'} class="btn btn--primary wwd-hero__cta">Book a Session</a>
        <a href={base + 'packages/'} class="wwd-hero__cta-ghost">
          See the packages
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    <a href="#premise" class="wwd-hero__scroll" aria-label="Scroll down">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="18" height="18">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </a>
  </section>

  <!-- ============================================================
       PREMISE — white bg, two-column grid
  ============================================================ -->
  <section class="section premise-section" id="premise">
    <div class="container premise-grid">
      <div class="premise__left">
        <span class="dynamic-mark">p</span>
        <h2 class="premise__heading">The only leadership discipline built entirely on non-verbal communication.</h2>
      </div>
      <div class="premise__right reveal">
        <p class="premise__body">Conducting is the only leadership discipline built entirely on non-verbal communication. A conductor cannot explain what they want while the music is happening. They must embody it — in posture, gesture, breathing, eye contact — and an ensemble of trained musicians will respond to the quality of that embodiment instantly.</p>
        <p class="premise__body premise__body--muted">This makes the conductor's podium the most honest feedback environment in any profession. If your gesture is ambiguous, the sound fractures. If your attention drifts, the ensemble loses cohesion. If you commit fully and communicate clearly, the voices align and the room fills with something unmistakable.</p>
        <p class="premise__body premise__body--muted">No debrief required. The music tells you exactly how you led.</p>
        <a href={base + 'packages/'} class="premise__link">
          Explore our packages
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FOR WHOM — charcoal bg, 3-card grid (dark t-card style)
  ============================================================ -->
  <section class="section whom-section" aria-label="Who it's for">
    <div class="container">
      <div class="whom-header">
        <span class="dynamic-mark" style="color: var(--sage);">ff</span>
        <h2 class="whom-heading">For Whom.</h2>
        <p class="whom-sub">Three audiences who consistently find the podium transformative.</p>
      </div>

      <div class="whom-grid">
        <article class="whom-card reveal">
          <h3 class="whom-card__title">Senior Leadership Teams</h3>
          <p class="whom-card__text">For boards, executive committees, and senior management teams. Conducting is an unusually effective way to surface communication dynamics in a small, high-stakes group. Best suited to our intensive multi-day programmes.</p>
          <a href={base + 'packages/'} class="whom-card__link">
            View packages
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

        <article class="whom-card reveal">
          <h3 class="whom-card__title">Whole-Company Training Days</h3>
          <p class="whom-card__text">For organisations running annual training days, conferences, or team-building programmes. Our in-office taster sessions are designed to work within your existing schedule and venue. Scales from 20 to 200 participants.</p>
          <a href={base + 'packages/'} class="whom-card__link">
            View packages
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

        <article class="whom-card reveal">
          <h3 class="whom-card__title">Executive Coaching Clients</h3>
          <p class="whom-card__text">For coaches seeking a distinctive experiential module for individual or small-group clients. A conducting session with a professional choir is unlike anything else in the executive development market.</p>
          <a href={base + 'packages/'} class="whom-card__link">
            View packages
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SESSION STRUCTURE — charcoal bg, numbered timeline
  ============================================================ -->
  <section class="section session-section" aria-label="Session structure">
    <div class="container">
      <div class="session-header">
        <span class="dynamic-mark" style="color: var(--sage);">mp</span>
        <h2 class="session-heading">What Happens<br/>in a Session.</h2>
        <p class="session-sub">Every session follows the same arc, whether it lasts half a day or a week.</p>
      </div>

      <div class="session-steps">
        <div class="session-step reveal">
          <span class="session-step__num">01</span>
          <div class="session-step__body">
            <h3 class="session-step__title">Warm-Up &amp; Orientation</h3>
            <p class="session-step__text">Your team learns the basics of choral sound — breathing, pitch, vowel shape — by singing together. This is not a performance; it's a shared physical experience that levels the room. CEOs and graduate trainees start in the same place.</p>
          </div>
        </div>

        <div class="session-step reveal">
          <span class="session-step__num">02</span>
          <div class="session-step__body">
            <h3 class="session-step__title">Conducting Fundamentals</h3>
            <p class="session-step__text">We teach the essential gestures: the beat pattern, the preparatory breath, the cue, the cut-off. These are simple to learn and extraordinarily difficult to do well. Your team begins to understand what it takes to give a clear instruction when you can't use words.</p>
          </div>
        </div>

        <div class="session-step reveal">
          <span class="session-step__num">03</span>
          <div class="session-step__body">
            <h3 class="session-step__title">Rehearsal with the Choir</h3>
            <p class="session-step__text">Each participant conducts our professional choir — the Alma Consort — in a prepared piece of music. The choir responds to exactly what you give them, nothing more and nothing less. This is where the learning happens: in the gap between what you intended and what the ensemble actually did.</p>
          </div>
        </div>

        <div class="session-step reveal">
          <span class="session-step__num">04</span>
          <div class="session-step__body">
            <h3 class="session-step__title">Debrief &amp; Reflection</h3>
            <p class="session-step__text">We close with structured discussion connecting the conducting experience to participants' working lives. What did the podium reveal about how you communicate? Where did you hesitate? When did the ensemble follow you most willingly, and why?</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       OUTCOMES BENTO — white bg, bento grid (mirrors homepage)
  ============================================================ -->
  <section class="section outcomes-section" aria-label="Learning outcomes">
    <div class="container">
      <div class="outcomes-header">
        <span class="dynamic-mark">mf</span>
        <h2 class="outcomes-heading">What<br/>Changes.</h2>
        <p class="outcomes-sub">Four things that shift every time a leader steps onto the podium.</p>
      </div>

      <div class="bento-grid">
        <article class="bento-card bento-card--large reveal">
          <span class="bento-card__num">01</span>
          <div class="bento-card__body">
            <h3 class="bento-card__title">Leadership &amp; Communication</h3>
            <p class="bento-card__text">How to give instructions that land first time. How to read a room while leading it. How to adjust in real time when your message isn't getting through. Conducting teaches all of this, and the feedback loop is measured in milliseconds, not quarterly reviews.</p>
          </div>
          <div class="bento-card__tag">Core Skill</div>
        </article>

        <article class="bento-card bento-card--medium reveal">
          <span class="bento-card__num">02</span>
          <div class="bento-card__body">
            <h3 class="bento-card__title">Team Cohesion &amp; Trust</h3>
            <p class="bento-card__text">Singing together synchronises breathing, heart rate, and attention. Your team will experience genuine mutual dependence — the kind that can't be manufactured by a trust fall or an escape room. The result is shared accomplishment, built on collective listening.</p>
          </div>
          <div class="bento-card__tag">Team</div>
        </article>

        <article class="bento-card bento-card--small reveal">
          <span class="bento-card__num">03</span>
          <div class="bento-card__body">
            <h3 class="bento-card__title">Presence &amp; Confidence</h3>
            <p class="bento-card__text">The podium strips away every crutch: no notes, no slides, no desk to stand behind. What remains is you, your body, and your willingness to be watched. Conducting — even briefly, even badly — recalibrates your sense of what you're capable of.</p>
          </div>
          <div class="bento-card__tag">Presence</div>
        </article>

        <article class="bento-card bento-card--small reveal">
          <span class="bento-card__num">04</span>
          <div class="bento-card__body">
            <h3 class="bento-card__title">Wellbeing &amp; Stress Relief</h3>
            <p class="bento-card__text">Group singing reduces cortisol, increases oxytocin, and improves self-reported mood. These are not soft claims — they are well-documented physiological effects. Your team will leave measurably less stressed than when they arrived.</p>
          </div>
          <div class="bento-card__tag">Wellbeing</div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CORPORATE TRAINING DAYS — white bg, two-path layout
  ============================================================ -->
  <section class="section corporate-section" id="corporate-training" aria-label="Corporate training days">
    <div class="container">
      <div class="corporate-header">
        <span class="dynamic-mark">f</span>
        <h2 class="corporate-heading">Book Your<br/>Training Day.</h2>
        <p class="corporate-sub">Every organisation arrives with a different brief. We work with both.</p>
      </div>

      <div class="corporate-grid">
        <article class="corporate-card corporate-card--dark reveal">
          <div class="corporate-card__label">Path 01</div>
          <h3 class="corporate-card__title">The Serious Work</h3>
          <p class="corporate-card__text">Some teams come to us because the usual approaches haven't landed. The workshops were fine. The keynotes were forgettable. The retreat produced a slide deck nobody opened again. What they're looking for — though they often don't have the words for it yet — is an experience that tells the truth about how they lead.</p>
          <p class="corporate-card__text">We design these days around your team's actual situation. If there are communication gaps, the podium will find them. If there are trust issues, the choir will surface them without anyone having to name names. The debrief is where the real conversation starts — and it tends to go places a facilitated workshop never quite reaches.</p>
          <ul class="corporate-card__features">
            <li>Half-day or full-day formats</li>
            <li>Tailored to your leadership priorities</li>
            <li>Structured debrief with measurable outcomes</li>
            <li>Available at our venue or yours</li>
          </ul>
          <a href={base + 'contact/#booking'} class="corporate-card__cta">
            Enquire about a development day
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

        <article class="corporate-card corporate-card--light reveal">
          <div class="corporate-card__label">Path 02</div>
          <h3 class="corporate-card__title">The Away Day</h3>
          <p class="corporate-card__text">Not every training day needs to carry the weight of the world. Sometimes you want your people in a room together, doing something unexpected — slightly out of their comfort zone, genuinely funny in places, and completely unlike last year's bowling alley.</p>
          <p class="corporate-card__text">Our half-day format is built for exactly this. It's high energy, accessible to anyone regardless of musical experience, and quietly more useful than it appears from the outside. Teams leave having laughed, having listened differently, and having made something together that they couldn't have made alone. The fact that it's also good for them is our business, not theirs.</p>
          <ul class="corporate-card__features">
            <li>Scales from 20 to 200 participants</li>
            <li>No musical experience required</li>
            <li>Works within your existing schedule and venue</li>
            <li>Pairs well with other training day elements</li>
          </ul>
          <a href={base + 'contact/#booking'} class="corporate-card__cta">
            Enquire about a team away day
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>
      </div>

      <div class="corporate-footer reveal">
        <p class="corporate-footer__text">Not sure which fits? Tell us about your team and we'll suggest a format. All enquiries begin with a free thirty-minute call with our music director.</p>
        <a href={base + 'contact/#booking'} class="btn btn--dark">Start the conversation</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA CLOSE — navy bg, stave lines SVG
  ============================================================ -->
  <section class="cta-close" aria-label="Call to action">
    <div class="cta-close__inner container">
      <div class="cta-close__text">
        <span class="dynamic-mark" style="color: var(--sage); opacity: 0.6;">fff</span>
        <h2 class="cta-close__heading">Ready to lead?</h2>
        <p class="cta-close__body">Book a free thirty-minute consultation with our music director and experience the podium for yourself.</p>
      </div>
      <div class="cta-close__actions">
        <a href={base + 'contact/#booking'} class="btn btn--primary">Book a Free Consultation</a>
        <a href={base + 'packages/'} class="cta-close__ghost">View Packages →</a>
      </div>
    </div>
    <svg class="cta-close__stave" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <line x1="0" y1="30" x2="1440" y2="30" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
      <line x1="0" y1="50" x2="1440" y2="50" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
      <line x1="0" y1="70" x2="1440" y2="70" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
      <line x1="0" y1="90" x2="1440" y2="90" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
      <line x1="0" y1="110" x2="1440" y2="110" stroke="#A3344A" stroke-width="0.5" opacity="0.12"/>
    </svg>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     HERO
  ============================================================ */
  .wwd-hero {
    position: relative;
    min-height: 100vh;
    background-color: var(--navy);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + 4rem) 6vw 4rem;
    text-align: center;
    gap: 2rem;
  }

  .wwd-hero__orb {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    pointer-events: none;
    animation: wwd-float 8s ease-in-out infinite;
  }

  .wwd-hero__orb--sage {
    background-color: #A3344A;
    filter: blur(130px);
    opacity: 0.15;
    top: 10%;
    left: -8%;
    animation-delay: 0s;
  }

  .wwd-hero__orb--blue {
    background-color: #bbe2f5;
    filter: blur(130px);
    opacity: 0.12;
    bottom: 15%;
    right: -6%;
    animation-delay: 4s;
  }

  @keyframes wwd-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-24px); }
  }

  .wwd-hero__arc {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: auto;
    opacity: 0.18;
    pointer-events: none;
  }

  .wwd-hero__badge {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border: 0.5px solid rgba(122, 31, 46, 0.4);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage);
    background: rgba(122, 31, 46, 0.08);
    backdrop-filter: blur(8px);
  }

  .wwd-hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--sage);
    animation: wwd-pulse 2s ease-in-out infinite;
  }

  @keyframes wwd-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .wwd-hero__headline {
    position: relative;
    z-index: 1;
  }

  .wwd-hero__line {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 18vw);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    display: block;
  }

  .wwd-hero__line--solid {
    color: var(--white);
  }

  .wwd-hero__line--outline {
    -webkit-text-stroke: 1px #A3344A;
    color: transparent;
  }

  .wwd-hero__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 560px;
  }

  .wwd-hero__tagline {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .wwd-hero__ctas {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .wwd-hero__cta {
    padding: 12px 28px;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
  }

  .wwd-hero__cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--sage);
    text-decoration: none;
    transition: gap 400ms var(--ease-out), opacity 400ms ease;
  }

  .wwd-hero__cta-ghost:hover {
    gap: 0.75rem;
    opacity: 0.8;
  }

  .wwd-hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 0.5px solid rgba(122, 31, 46, 0.4);
    border-radius: 50%;
    color: var(--sage);
    animation: wwd-bounce 1.6s ease-in-out infinite;
    transition: background-color 300ms ease;
  }

  .wwd-hero__scroll:hover {
    background-color: rgba(122, 31, 46, 0.15);
  }

  @keyframes wwd-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(5px); }
  }

  /* ============================================================
     PREMISE
  ============================================================ */
  .premise-section {
    padding: 7rem 0;
  }

  .premise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .premise__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--navy);
    margin-top: 0.75rem;
  }

  .premise__body {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--navy);
    margin-bottom: 1.25rem;
    max-width: 480px;
  }

  .premise__body--muted {
    color: var(--taupe);
  }

  .premise__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--navy);
    text-decoration: none;
    border-bottom: 0.5px solid rgba(23,30,25,0.25);
    padding-bottom: 2px;
    transition: border-color 300ms ease, gap 300ms ease;
    margin-top: 0.5rem;
  }

  .premise__link:hover {
    border-color: var(--navy);
    gap: 0.75rem;
  }

  @media (min-width: 900px) {
    .premise-grid {
      grid-template-columns: 5fr 7fr;
      gap: 6rem;
      align-items: start;
    }
  }

  /* ============================================================
     SESSION STRUCTURE
  ============================================================ */
  .session-section {
    background-color: var(--charcoal);
    padding: 7rem 0;
  }

  .session-header {
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .session-heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
    margin-top: 0.5rem;
  }

  .session-sub {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.9);
    max-width: 480px;
    margin-top: 1rem;
    line-height: 1.6;
  }

  .session-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .session-step {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
    border-top: 0.5px solid rgba(122, 31, 46, 0.18);
    align-items: start;
  }

  .session-step:last-child {
    border-bottom: 0.5px solid rgba(122, 31, 46, 0.18);
  }

  .session-step__num {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--sage);
    opacity: 0.75;
    padding-top: 0.15rem;
  }

  .session-step__title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    line-height: 1;
