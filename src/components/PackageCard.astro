---
interface Props {
  title: string;
  price?: string;
  description: string;
  ctaText: string;
  ctaLink: string;
}

const { title, price, description, ctaText, ctaLink } = Astro.props;
---

<div class="package-card">
  <div class="package-card__header">
    <h3>{title}</h3>
    {price && <span class="package-card__price">{price}</span>}
  </div>
  <p class="package-card__desc">{description}</p>
  <a href={ctaLink} class="package-card__cta">{ctaText} →</a>
</div>

<style>
  .package-card {
    display: flex;
    flex-direction: column;
    padding: 2.25rem 0;
    border-top: 1px solid var(--border-subtle);
  }

  .package-card__header {
    margin-bottom: 1rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .package-card__header h3 {
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .package-card__price {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
    white-space: nowrap;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .package-card__desc {
    flex: 1;
    color: var(--mid-grey);
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .package-card__cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--navy);
    text-decoration: none;
    border-bottom: 1px solid var(--gold);
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease;
    align-self: flex-start;
  }

  .package-card__cta:hover {
    color: var(--gold);
    border-color: var(--gold);
  }
</style>
