---
interface Props {
  title: string;
  price?: string;
  description: string;
  ctaText: string;
  ctaLink: string;
}

const { title, price, description, ctaText, ctaLink } = Astro.props;
---

<div class="package-card">
  <div class="package-card__header">
    <h3>{title}</h3>
    {price && <span class="package-card__price">{price}</span>}
  </div>
  <p class="package-card__desc">{description}</p>
  <a href={ctaLink} class="package-card__cta">
    {ctaText}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>
</div>

<style>
  .package-card {
    display: flex;
    flex-direction: column;
    padding: 2.25rem 0;
    border-top: 1px solid var(--border-subtle);
    transition: border-color 400ms ease;
  }

  .package-card:hover {
    border-color: rgba(163, 52, 74, 0.25);
  }

  .package-card__header {
    margin-bottom: 1rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .package-card__header h3 {
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .package-card__price {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--gold);
    white-space: nowrap;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .package-card__desc {
    flex: 1;
    color: var(--mid-grey);
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .package-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--navy);
    text-decoration: none;
    border-bottom: 1px solid rgba(163, 52, 74, 0.3);
    padding-bottom: 2px;
    transition: color 300ms ease, border-color 300ms ease, gap 300ms ease;
    align-self: flex-start;
  }

  .package-card__cta:hover {
    color: var(--gold);
    border-color: var(--gold);
    gap: 0.75rem;
  }
</style>
