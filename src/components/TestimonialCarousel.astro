---
const testimonials = [
  {
    quote: "We've run every kind of team-building exercise imaginable. This was the first time I saw our entire senior leadership team genuinely out of their comfort zone — and genuinely better for it.",
    name: "[Name]",
    title: "Head of People, [Company]",
    initials: "HP"
  },
  {
    quote: "I didn't expect to learn more about my communication style in two hours with a choir than I did in a year of executive coaching. The feedback from the music is instant and unambiguous.",
    name: "[Name]",
    title: "Managing Director, [Company]",
    initials: "MD"
  },
  {
    quote: "Our team still talks about it six months later. Not as a fun day — as a turning point in how we work together.",
    name: "[Name]",
    title: "L&D Manager, [Company]",
    initials: "LM"
  }
];
---

<div class="testimonials">
  <div class="testimonials__track" id="testimonial-track">
    {testimonials.map((t, i) => (
      <blockquote
        class:list={['testimonials__slide', { 'testimonials__slide--active': i === 0 }]}
        data-index={i}
      >
        <p class="testimonials__quote">{t.quote}</p>
        <footer class="testimonials__bio">
          <div class="testimonials__avatar" aria-hidden="true">{t.initials}</div>
          <div class="testimonials__meta">
            <strong class="testimonials__name">{t.name}</strong>
            <span class="testimonials__role">{t.title}</span>
          </div>
        </footer>
      </blockquote>
    ))}
  </div>

  <div class="testimonials__dots" role="tablist" aria-label="Testimonial navigation">
    {testimonials.map((_, i) => (
      <button
        class:list={['testimonials__dot', { 'testimonials__dot--active': i === 0 }]}
        data-dot={i}
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-label={`Show testimonial ${i + 1}`}
      />
    ))}
  </div>
</div>

<style>
  .testimonials {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .testimonials__track {
    position: relative;
    min-height: 280px;
  }

  .testimonials__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 600ms var(--ease-out);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 1rem;
  }

  .testimonials__slide--active {
    opacity: 1;
    position: relative;
  }

  .testimonials__quote {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5rem, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 2.5rem;
  }

  .testimonials__bio {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
  }

  .testimonials__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: var(--sage);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: var(--navy);
    flex-shrink: 0;
  }

  .testimonials__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
  }

  .testimonials__name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--white);
    font-weight: 400;
  }

  .testimonials__role {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.02em;
  }

  .testimonials__dots {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 3rem;
  }

  .testimonials__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 0.5px solid rgba(183, 198, 194, 0.4);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background-color 300ms ease, border-color 300ms ease, transform 300ms ease;
  }

  .testimonials__dot--active {
    background: var(--sage);
    border-color: var(--sage);
    transform: scale(1.4);
  }
</style>

<script>
  const slides = document.querySelectorAll('.testimonials__slide');
  const dots = document.querySelectorAll('.testimonials__dot');
  let current = 0;

  function show(index: number) {
    slides.forEach(s => s.classList.remove('testimonials__slide--active'));
    dots.forEach(d => {
      d.classList.remove('testimonials__dot--active');
      d.setAttribute('aria-selected', 'false');
    });
    slides[index]?.classList.add('testimonials__slide--active');
    const activeDot = dots[index] as HTMLElement | undefined;
    activeDot?.classList.add('testimonials__dot--active');
    activeDot?.setAttribute('aria-selected', 'true');
    current = index;
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const i = Number((dot as HTMLElement).dataset.dot);
      show(i);
    });
  });

  // No auto-rotation — manual navigation only
</script>
