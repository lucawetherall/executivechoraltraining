---
interface Props {
  heading: string;
  description: string;
  icon: string;
  number?: string;
}

const { heading, description, icon, number } = Astro.props;
---

<div class="outcome-tile">
  <div class="outcome-tile__top">
    {number && <span class="outcome-tile__num">{number}</span>}
    <div class="outcome-tile__icon" set:html={icon} />
  </div>
  <h3>{heading}</h3>
  <p>{description}</p>
</div>

<style>
  .outcome-tile {
    padding: 2.5rem 2.5rem 2.5rem 0;
    border-top: 1px solid var(--border-subtle);
    position: relative;
  }

  .outcome-tile__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .outcome-tile__num {
    font-family: var(--font-serif);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--gold);
    line-height: 1;
    padding-top: 2px;
  }

  .outcome-tile__icon {
    width: 36px;
    height: 36px;
    color: rgba(27, 42, 74, 0.25);
    flex-shrink: 0;
  }

  .outcome-tile__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .outcome-tile h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .outcome-tile p {
    color: var(--mid-grey);
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
  }
</style>
