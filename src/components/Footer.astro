---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="footer">

  <!-- Stave divider -->
  <svg class="footer__stave" viewBox="0 0 1440 48" preserveAspectRatio="none" aria-hidden="true">
    <line x1="0" y1="12" x2="1440" y2="12" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
    <line x1="0" y1="20" x2="1440" y2="20" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
    <line x1="0" y1="28" x2="1440" y2="28" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
    <line x1="0" y1="36" x2="1440" y2="36" stroke="#b7c6c2" stroke-width="0.5" opacity="0.08"/>
  </svg>

  <!-- Main footer body -->
  <div class="footer__body container">

    <!-- Brand column -->
    <div class="footer__brand">
      <a href={base} class="footer__logo" aria-label="ECCT Home">ECCT</a>
      <p class="footer__tagline">Choral conducting training that builds presence, communication, and trust.</p>
      <a href="mailto:hello@executivechoral.co.uk" class="footer__email">
        hello@executivechoral.co.uk
      </a>
    </div>

    <!-- Nav columns -->
    <div class="footer__nav-group">
      <div class="footer__nav-col">
        <span class="footer__nav-heading">Explore</span>
        <nav aria-label="Footer navigation">
          <a href={base + 'what-we-do/'} class="footer__nav-link">What We Do</a>
          <a href={base + 'packages/'} class="footer__nav-link">Packages</a>
          <a href={base + 'about/'} class="footer__nav-link">About</a>
          <a href={base + 'insights/'} class="footer__nav-link">Insights</a>
          <a href={base + 'contact/'} class="footer__nav-link">Contact</a>
        </nav>
      </div>

      <div class="footer__nav-col">
        <span class="footer__nav-heading">Programmes</span>
        <nav aria-label="Programmes navigation">
          <a href={base + 'packages/#in-office'} class="footer__nav-link">Taster Session</a>
          <a href={base + 'packages/#in-office'} class="footer__nav-link">Full Day</a>
          <a href={base + 'packages/#in-office'} class="footer__nav-link">Three-Day</a>
          <a href={base + 'packages/#in-office'} class="footer__nav-link">Week-Long</a>
          <a href={base + 'packages/#church-venue'} class="footer__nav-link">Church Venues</a>
        </nav>
      </div>
    </div>

    <!-- CTA column -->
    <div class="footer__cta-col">
      <span class="footer__nav-heading">Ready to lead?</span>
      <p class="footer__cta-text">Book a free thirty-minute consultation with our music director.</p>
      <a href={base + 'contact/#booking'} class="btn btn--secondary footer__cta-btn">Book a Session</a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom container">
    <p>&copy; {year} Executive Choral Conducting Training. All rights reserved.</p>
    <div class="footer__legal">
      <a href={base + 'privacy/'}>Privacy Policy</a>
    </div>
  </div>

</footer>

<style>
  .footer {
    background-color: var(--navy);
    color: var(--white);
  }

  .footer__stave {
    display: block;
    width: 100%;
    height: 48px;
  }

  /* Body */
  .footer__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 4rem;
    border-top: 0.5px solid rgba(183, 198, 194, 0.08);
  }

  /* Brand col */
  .footer__logo {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.375rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .footer__tagline {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--taupe);
    max-width: 260px;
    margin-bottom: 1.5rem;
  }

  .footer__email {
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--sage);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    transition: opacity 300ms ease;
  }

  .footer__email::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 0.5px;
    background-color: var(--sage);
    transition: width 300ms var(--ease-out);
  }

  .footer__email:hover::after {
    width: 100%;
  }

  /* Nav group */
  .footer__nav-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .footer__nav-heading {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.5;
    margin-bottom: 1.25rem;
  }

  .footer__nav-col nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__nav-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 300ms ease, transform 300ms ease;
    display: inline-block;
  }

  .footer__nav-link:hover {
    color: var(--white);
    transform: translateX(3px);
  }

  /* CTA col */
  .footer__cta-col {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer__cta-text {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--taupe);
    max-width: 240px;
    margin: 0.75rem 0 1.5rem;
  }

  .footer__cta-btn {
    align-self: flex-start;
    font-size: 0.625rem;
    padding: 10px 20px;
  }

  /* Bottom bar */
  .footer__bottom {
    padding-top: 1.5rem;
    padding-bottom: 2rem;
    border-top: 0.5px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__bottom p,
  .footer__bottom a {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.4;
  }

  .footer__bottom a:hover {
    opacity: 0.7;
  }

  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer__body {
      grid-template-columns: 2fr 2fr 1.5fr;
      gap: 4rem;
      align-items: start;
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
