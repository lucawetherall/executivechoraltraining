---
const year = new Date().getFullYear();
---

<footer class="footer">

  <!-- Stave divider -->
  <svg class="footer__stave" viewBox="0 0 1440 64" preserveAspectRatio="none" aria-hidden="true">
    <line x1="0" y1="20" x2="1440" y2="20" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="28" x2="1440" y2="28" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="36" x2="1440" y2="36" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="44" x2="1440" y2="44" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="52" x2="1440" y2="52" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
  </svg>

  <!-- CTA block — Loud (ff) -->
  <div class="footer__cta">
    <span class="footer__mark">ff</span>
    <h2 class="footer__heading">Let's<br/>Create.</h2>
    <a href="mailto:hello@executivechoral.co.uk" class="footer__email">
      hello@executivechoral.co.uk
    </a>

    <div class="footer__nav-links">
      <a href="/what-we-do/">What We Do</a>
      <a href="/packages/">Packages</a>
      <a href="/about/">About</a>
      <a href="/insights/">Insights</a>
      <a href="/contact/">Contact</a>
    </div>
  </div>

  <!-- Stave divider -->
  <svg class="footer__stave" viewBox="0 0 1440 64" preserveAspectRatio="none" aria-hidden="true">
    <line x1="0" y1="20" x2="1440" y2="20" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="28" x2="1440" y2="28" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="36" x2="1440" y2="36" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="44" x2="1440" y2="44" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
    <line x1="0" y1="52" x2="1440" y2="52" stroke="#b7c6c2" stroke-width="0.5" opacity="0.12"/>
  </svg>

  <!-- Bottom bar — Whisper -->
  <div class="footer__bottom">
    <p>&copy; {year} Executive Choral Conducting Training</p>
    <div class="footer__legal">
      <a href="/privacy/">Privacy Policy</a>
    </div>
  </div>

</footer>

<style>
  .footer {
    background-color: var(--navy);
    color: var(--white);
  }

  .footer__stave {
    display: block;
    width: 100%;
    height: 64px;
  }

  /* CTA block */
  .footer__cta {
    padding: 5rem 6vw 5rem;
  }

  .footer__mark {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    opacity: 0.4;
    margin-bottom: 1.5rem;
  }

  .footer__heading {
    font-family: var(--font-display);
    font-size: clamp(5rem, 9rem, 9rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 2.5rem;
  }

  .footer__email {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 2.5rem, 2.5rem);
    font-weight: 300;
    color: var(--sage);
    text-decoration: none;
    position: relative;
    margin-bottom: 4rem;
    padding-bottom: 2px;
  }

  .footer__email::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--sage);
    transition: width 300ms var(--ease-out);
  }

  .footer__email:hover::after {
    width: 100%;
  }

  .footer__nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer__nav-links a {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.5;
    text-decoration: none;
    transition: color 600ms var(--ease-out), opacity 600ms var(--ease-out), transform 600ms var(--ease-out);
  }

  .footer__nav-links a:hover {
    color: var(--white);
    opacity: 1;
    transform: translateX(4px);
  }

  /* Bottom bar */
  .footer__bottom {
    padding: 1.5rem 6vw;
    border-top: 0.5px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__bottom p,
  .footer__bottom a {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.5;
  }

  .footer__bottom a:hover {
    opacity: 0.8;
  }

  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
