---
const base = import.meta.env.BASE_URL;
const fullPath = Astro.url.pathname;
const currentPath = base.length > 1
  ? fullPath.replace(base.endsWith('/') ? base.slice(0, -1) : base, '') || '/'
  : fullPath;

const navLinks = [
  { href: '/what-we-do/', label: 'What We Do' },
  { href: '/packages/', label: 'Packages' },
  { href: '/about/', label: 'About' },
  { href: '/insights/', label: 'Insights' },
];
---

<header class="nav" id="nav" role="banner" data-scrolled="false">
  <a href={base} class="nav__logo" aria-label="ECT Home">ECT</a>

  <nav class="nav__links" id="nav-links" aria-label="Main navigation">
    {navLinks.map(link => (
      <a
        href={base + link.href.slice(1)}
        class:list={['nav__link', { 'nav__link--active': currentPath === link.href }]}
      >
        {link.label}
      </a>
    ))}
  </nav>

  <a href={base + 'contact/#booking'} class="btn btn--nav nav__cta">Book a Session</a>

  <button class="nav__hamburger" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<!-- Mobile menu overlay -->
<div class="nav__mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav aria-label="Mobile navigation">
    <a href={base} class="nav__mobile-link" style="--i:0">Home</a>
    {navLinks.map((link, i) => (
      <a href={base + link.href.slice(1)} class="nav__mobile-link" style={`--i:${i + 1}`}>{link.label}</a>
    ))}
    <a href={base + 'contact/'} class="nav__mobile-link" style="--i:5">Contact</a>
  </nav>
  <a href={base + 'contact/#booking'} class="nav__mobile-cta" style="--i:6">Book a Session →</a>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    mix-blend-mode: difference;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 48px;
    background: transparent;
    pointer-events: none;
    transition: padding 400ms var(--ease-out), background-color 400ms ease;
  }

  .nav[data-scrolled="true"] {
    mix-blend-mode: normal;
    background: rgba(23, 30, 25, 0.94);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    padding: 16px 48px;
    border-bottom: 1px solid rgba(163, 52, 74, 0.1);
  }

  .nav > * {
    pointer-events: auto;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: 1.375rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    line-height: 1;
    transition: opacity 300ms ease;
  }

  .nav__logo:hover {
    opacity: 0.7;
  }

  .nav__links {
    display: none;
    gap: 2.5rem;
    align-items: center;
  }

  .nav__link {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    transition: opacity 300ms ease;
    position: relative;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--sage);
    transition: width 400ms var(--ease-out);
  }

  .nav__link:hover::after,
  .nav__link--active::after {
    width: 100%;
  }

  .nav__link:hover {
    opacity: 0.8;
  }

  .nav__link--active {
    opacity: 0.6;
  }

  .nav__cta {
    display: none;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
  }

  /* Hamburger */
  .nav__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .nav__hamburger span {
    display: block;
    width: 22px;
    height: 1px;
    background-color: var(--white);
    transition: all 400ms var(--ease-out);
    transform-origin: center;
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  /* Mobile menu overlay */
  .nav__mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 999;
    background-color: var(--navy);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 2.5rem 4rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 500ms var(--ease-out);
  }

  .nav__mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Staggered link animations */
  .nav__mobile-link,
  .nav__mobile-cta {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 400ms var(--ease-out), transform 400ms var(--ease-out), color 300ms ease;
  }

  .nav__mobile-menu.open .nav__mobile-link,
  .nav__mobile-menu.open .nav__mobile-cta {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--i) * 70ms + 150ms);
  }

  .nav__mobile-link {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 3.5rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
    padding: 0.6rem 0;
    line-height: 1;
    border-bottom: 1px solid rgba(163, 52, 74, 0.12);
  }

  .nav__mobile-link:hover {
    color: var(--sage);
  }

  .nav__mobile-cta {
    display: inline-block;
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
  }

  @media (min-width: 1024px) {
    .nav__links {
      display: flex;
    }

    .nav__cta {
      display: inline-block;
    }

    .nav__hamburger {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .nav {
      padding: 24px 24px;
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.setAttribute('data-scrolled', window.scrollY > 60 ? 'true' : 'false');
  }, { passive: true });

  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    const opening = !isOpen;
    toggle.setAttribute('aria-expanded', String(opening));
    mobileMenu?.classList.toggle('open', opening);
    mobileMenu?.setAttribute('aria-hidden', String(!opening));
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.remove('open');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
