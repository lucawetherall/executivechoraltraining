---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/what-we-do/', label: 'What We Do' },
  { href: '/packages/', label: 'Packages' },
  { href: '/about/', label: 'About' },
  { href: '/insights/', label: 'Insights' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="nav" id="nav">
  <div class="nav__inner container">
    <a href="/" class="nav__logo" aria-label="ECCT Home">
      <span class="nav__logo-text">ECCT</span>
    </a>

    <nav class="nav__links" id="nav-links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav__link', { 'nav__link--active': currentPath === link.href }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a href="/contact/#booking" class="btn btn--primary nav__cta">
      Book Your Free Consultation
    </a>

    <button class="nav__hamburger" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background-color: var(--white);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.08);
    height: var(--nav-height);
    display: flex;
    align-items: center;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .nav__logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav__logo-text {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: 0.05em;
  }

  .nav__links {
    display: none;
    gap: 2rem;
  }

  .nav__link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--navy);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--gold);
  }

  .nav__cta {
    display: none;
    font-size: 0.85rem;
    padding: 0.625rem 1.25rem;
  }

  /* Hamburger */
  .nav__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 1001;
  }

  .nav__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--navy);
    transition: all 0.3s ease;
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* Mobile menu */
  .nav__links--open {
    display: flex;
    flex-direction: column;
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--white);
    padding: 2rem 1.5rem;
    gap: 1.5rem;
    z-index: 999;
  }

  .nav__links--open .nav__link {
    font-size: 1.2rem;
  }

  @media (min-width: 1024px) {
    .nav__links {
      display: flex;
    }

    .nav__cta {
      display: inline-block;
    }

    .nav__hamburger {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    links?.classList.toggle('nav__links--open');
  });
</script>
